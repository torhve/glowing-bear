{
  "extends": "./src-svelte/.svelte-kit/tsconfig.json",
  "compilerOptions": {
    "incremental": true,
    "target": "es2022",
    "module": "es2022",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "disableSizeLimit": true,
    "noUncheckedIndexedAccess": true,
    "types": ["vite/client", "node"]
  },
  "include": ["src-svelte/src/**/*.d.ts", "src-svelte/src/**/*.js", "src-svelte/src/**/*.ts", "src-svelte/src/**/*.svelte", "vite.config.ts"]
}
