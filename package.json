{
  "name": "glowing-bear",
  "private": true,
  "version": "0.21.0",
  "description": "Glowing Bear — A web client for WeeChat",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "prebuild": "node static/generate-icons.mjs",
    "build": "vite build",
    "build:docker": "vite build",
    "generate-icons": "node static/generate-icons.mjs",
    "generate-icns": "node static/generate-icns.mjs",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json",
    "lint": "eslint src-svelte/src",
    "knip": "knip",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --config=src-svelte/e2e/playwright.config.ts",
    "test:e2e:watch": "playwright test --ui --config=src-svelte/e2e/playwright.config.ts",
    "test:e2e:debug": "playwright test --debug --config=src-svelte/e2e/playwright.config.ts",
    "irc:server": "npx tsx test/irc-server/index.ts",
    "irc:start": "bash test/fixtures/gbtest/start.sh",
    "irc:stop": "bash test/fixtures/gbtest/stop.sh",
    "tauri": "npx tauri",
    "tauri:dev": "npx tauri dev",
    "tauri:build": "npx tauri build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@resvg/resvg-js": "^2.6.2",
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.68.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "^2.11.3",
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^10.6.0",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "knip": "^6.23.0",
    "sharp": "^0.35.2",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "svelte-eslint-parser": "^1.8.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^7.3.6",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@lucide/svelte": "^1.21.0",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-window-state": "^2.4.1",
    "@vite-pwa/sveltekit": "^1.1.0",
    "dompurify": "^3.4.11",
    "fflate": "^0.8.3",
    "zlibjs": "^0.3.1"
  }
}
