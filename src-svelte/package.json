{
  "name": "glowing-bear-svelte",
  "private": true,
  "version": "0.11.0",
  "description": "Glowing Bear - Svelte frontend for WeeChat",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && cp build/404.html build/index.html",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts",
    "test:e2e:watch": "playwright test --ui --config=e2e/playwright.config.ts",
    "test:e2e:debug": "playwright test --debug --config=e2e/playwright.config.ts",
    "test:e2e:all": "bash ../test/fixtures/gbtest/start.sh && playwright test --config=e2e/playwright.config.ts && bash ../test/fixtures/gbtest/stop.sh",
    "test:e2e:all:watch": "bash ../test/fixtures/gbtest/start.sh && playwright test --ui --config=e2e/playwright.config.ts && bash ../test/fixtures/gbtest/stop.sh",
    "irc:server": "npx tsx test/irc-server/index.ts",
    "irc:start": "bash ../test/fixtures/gbtest/start.sh",
    "irc:stop": "bash ../test/fixtures/gbtest/stop.sh",
    "tauri": "cd ../src-tauri && cargo tauri",
    "tauri:dev": "cd ../src-tauri && cargo tauri dev",
    "tauri:build": "cd ../src-tauri && cargo tauri build"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.17.2",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.3.1",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "eslint": "^9.21.0",
    "eslint-plugin-svelte": "^2.46.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "svelte": "^5.22.8",
    "svelte-check": "^4.1.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.61.0",
    "vite": "^6.2.4",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@lucide/svelte": "^1.18.0",
    "@tauri-apps/api": "^2.5.0",
    "@vite-pwa/sveltekit": "^1.1.0",
    "dompurify": "^3.4.10",
    "fflate": "^0.8.3",
    "linkify-string": "^4.1.1",
    "linkifyjs": "^4.1.1",
    "zlibjs": "^0.3.1"
  }
}
