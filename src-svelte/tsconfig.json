{
  "extends": "./.svelte-kit/tsconfig.json",
  "compilerOptions": {
    "incremental": true,
    "target": "es2022",
    "module": "es2022",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "disableSizeLimit": true,
    "noUncheckedIndexedAccess": true
  },
  "include": ["src/**/*.d.ts", "src/**/*.js", "src/**/*.ts", "src/**/*.svelte", "vite.config.ts"]
}
