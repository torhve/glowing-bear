# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# JSON
[*.json]
indent_size = 4

# YAML / YML
[*.{yaml,yml}]
indent_size = 4

# HTML
[*.html]
indent_size = 4

# Markdown
[*.md]
indent_size = 4
