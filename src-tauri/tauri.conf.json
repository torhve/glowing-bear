{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Glowing Bear",
  "version": "0.10.0",
  "identifier": "org.glowing-bear",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run start",
    "devUrl": "http://localhost:8080/",
    "frontendDist": "../build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "fullscreen": false,
        "height": 600,
        "resizable": true,
        "title": "Glowing Bear",
        "titleBarStyle": "Overlay",
        "width": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "SocialNetworking",
    "copyright": "Glowing Bear developers",
    "icon": [
      "../src/assets/img/favicon.png",
      "../src/assets/img/glowing_bear_128x128.png",
      "../src/assets/img/glowing-bear.png",
      "../src/assets/img/glowing-bear.icns",
      "../src/assets/img/glowing_bear_128x128.ico"
    ],
    "longDescription": "Glowing Bear is a web frontend for the WeeChat IRC client",
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    },
    "resources": [],
    "shortDescription": "",
    "targets": "all",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "timestampUrl": ""
    }
  }
}
